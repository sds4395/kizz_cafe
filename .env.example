# 카카오맵 JavaScript 키
# https://developers.kakao.com → 내 애플리케이션 → 앱 키 → "JavaScript 키"
# (그리고 플랫폼 > Web 에 사용할 도메인을 등록해야 합니다. 예: http://localhost:5173)
VITE_KAKAO_MAP_KEY=여기에_카카오_자바스크립트_키

# Supabase (공유 백엔드)
# https://supabase.com → 프로젝트 → Project Settings → API
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=여기에_anon_public_키
